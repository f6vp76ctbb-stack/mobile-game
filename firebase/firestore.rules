rules_version = '2';

// Qubble Firestore rules — the ONLY server-side gate for the shared
// leaderboard. Deploy: Firebase Console → Firestore Database → Regeln →
// paste this file → "Veröffentlichen". Keep in sync with the client-side
// mirror in lib/services/leaderboard.dart.
service cloud.firestore {
  match /databases/{database}/documents {

    match /leaderboard/{uid} {
      // Public read: the app (native + web PWA) lists the top scores.
      allow read: if true;

      // Players write ONLY their own document (anonymous auth uid), with a
      // validated name/score. Scores can never be lowered, entries never
      // deleted.
      allow create: if isOwner(uid) && validEntry();
      allow update: if isOwner(uid) && validEntry()
                    && request.resource.data.score >= resource.data.score;
      allow delete: if false;

      function isOwner(uid) {
        return request.auth != null && request.auth.uid == uid;
      }

      function validEntry() {
        return request.resource.data.keys().hasOnly(['name', 'score'])
            && request.resource.data.name is string
            && request.resource.data.name.matches('[A-Za-z0-9 _-]{2,14}')
            && request.resource.data.score is int
            && request.resource.data.score > 0
            && request.resource.data.score <= 100000000;
      }
    }

    // Everything else is locked.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
